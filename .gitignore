# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ignore files created by npm
node_modules
package-lock.json

# Ignore the vendor file and bundle for alternative installation
vendor/
.bundle/

# Ignore folders related to IDEs
.vscode/

# Ignore macOS system files
.DS_Store
**/.DS_Store

# Unpublished drafts kept locally in the repo but deliberately NOT public.
# Anything committed here is served to the public web, so drafts Ida has not
# explicitly chosen to link must never be tracked. These sit in papers/ only
# for convenience; their real home is ../source_materials/. Do not `git add -A`
# in this repo (it would stage them) -- always add explicit paths. A .docx is
# never a public deliverable, so all of papers/*.docx is ignored.
papers/*.docx
papers/City-Country Gap WD-S-19-03165.pdf